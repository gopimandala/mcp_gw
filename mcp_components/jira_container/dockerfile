# --- Stage 1: Build dependencies ---
FROM python:3.12-slim AS builder
WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
# Install to a prefix reachable by others, not /root
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# --- Stage 2: Runtime ---
FROM python:3.12-slim
WORKDIR /app

# Copy from the custom prefix
COPY --from=builder /install /usr/local
ENV PYTHONPATH=/app

# Copy app files
COPY jira_server_langsmith.py .
COPY shared/ ./shared/

# Security: Create non-root user
RUN useradd -m appuser && chown -R appuser /app
USER appuser

EXPOSE 8020

# Use uvicorn for the ASGI app
# Note: Ensure port 8020 matches your docker run command
CMD ["uvicorn", "jira_server_langsmith:app", "--host", "0.0.0.0", "--port", "8020"]
